# ──────────────────────────────────────────────────────────
# FlipLearn – Environment Variables
# Copy this file to .env and fill in values.
# .env is gitignored and NEVER committed to source control.
# ──────────────────────────────────────────────────────────

# Django secret key (generate one at https://djecrety.ir/ or use:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hostnames (no spaces)
# Railway:  your-app.up.railway.app
# Render:   fliplearn.onrender.com
# Custom:   yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Full HTTPS origins trusted for CSRF (must match ALLOWED_HOSTS)
CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app

# PostgreSQL connection string (auto-set by Railway/Render when you attach a DB)
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# Leave blank to use SQLite locally.
DATABASE_URL=

# Groq API key for the AI chatbot (https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here
